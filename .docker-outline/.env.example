NODE_ENV=production

# –––––––––––––––– REQUIRED SETTINGS ––––––––––––––––

# URL should point to the fully qualified, publicly accessible URL
# For local: http://localhost:3000
# For production: https://your-domain.com
URL=http://localhost:3000

PORT=3000

# Generate using: openssl rand -hex 32
SECRET_KEY=your_secret_key_here

# Generate using: openssl rand -hex 32
UTILS_SECRET=your_utils_secret_here

# Database connection
DATABASE_URL=postgres://outline:outline_password_change_me@postgres:5432/outline
PGSSLMODE=disable

# Redis connection
REDIS_URL=redis://redis:6379

# –––––––––––––––– FILE STORAGE ––––––––––––––––

FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE=262144000

# –––––––––––––––– AUTHENTICATION ––––––––––––––––
# Configure at least ONE authentication provider

# Slack
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Microsoft Entra / Azure AD
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_RESOURCE_APP_ID=

# Generic OIDC
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_AUTH_URI=
# OIDC_TOKEN_URI=
# OIDC_USERINFO_URI=
# OIDC_DISPLAY_NAME=OpenID Connect

# –––––––––––––––– OPTIONAL ––––––––––––––––

DEFAULT_LANGUAGE=en_US
WEB_CONCURRENCY=1
FORCE_HTTPS=false
RATE_LIMITER_ENABLED=true
ENABLE_UPDATES=true
LOG_LEVEL=info
